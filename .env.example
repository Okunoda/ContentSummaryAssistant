# ==========================================
# VideoCraw 配置文件
# 复制此文件为 .env 并修改对应配置
# ==========================================

# --- LLM 配置 (支持 OpenAI 兼容 API) ---
# 可以使用 OpenAI、DeepSeek、通义千问、智谱 GLM 等任何兼容接口
LLM_API_KEY=sk-your-api-key-here
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# DeepSeek 示例:
# LLM_API_BASE=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# 通义千问 (阿里云) 示例:
# LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus

# 智谱 GLM 示例:
# LLM_API_BASE=https://open.bigmodel.cn/api/paas/v4
# LLM_MODEL=glm-4-flash

# --- Whisper 语音转文字配置 ---
# 模型大小: tiny, base, small, medium, large-v3
# 模型越大准确度越高，但速度越慢、显存占用越多
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# --- 小红书 Cookie（可选，提升下载成功率）---
# 从浏览器登录 xiaohongshu.com 后，F12 → Application → Cookies → 复制完整 Cookie
XHS_COOKIE=

# --- 代理配置说明 ---
# B站有地域限制，海外用户需要中国大陆代理
# 在终端中设置代理环境变量即可（yt-dlp 会自动读取）：
#   export HTTP_PROXY=http://127.0.0.1:7890
#   export HTTPS_PROXY=http://127.0.0.1:7890

# --- ffmpeg 路径（可选）---
# 如果 ffmpeg 不在系统 PATH 中，手动指定路径
# FFMPEG_PATH=/usr/local/bin/ffmpeg

# --- 下载/输出目录（可选）---
# DOWNLOAD_DIR=./downloads
# OUTPUT_DIR=./output
